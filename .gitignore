# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/apps/**/node_modules/
/packages/**/node_modules/
/apps/mobile/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# env files
.env.local
.env.production

# next.js
/.next/
/apps/**/.next/
/out/
/.cxx/

# production
/build
/apps/mobile/android/build/
/apps/mobile/android/app/build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# expo
.expo/
apps/mobile/.expo/
apps/mobile/android/keystore.properties
apps/mobile/android/**/*.jks
apps/mobile/android/**/*.keystore

# typescript
*.tsbuildinfo
next-env.d.ts
